# Course Builder Backend — environment variables

NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coursebuilder

# CORS / frontend
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
# ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.example.com

# Coordinator (required in production for JWT validation)
COORDINATOR_URL=http://localhost:5000
# COORDINATOR_API_URL=http://localhost:5000

# Service identity for Coordinator auth validation envelope
AUTH_REQUESTER_SERVICE=course-builder
SERVICE_NAME=course-builder-service

# Inter-service signing
# PRIVATE_KEY=
# COORDINATOR_PUBLIC_KEY=

# Auth
AUTH_VALIDATION_TIMEOUT_MS=10000

# Local dev/test only — never enable in production
ENABLE_MOCK_AUTH=true

# Legacy (replaced by Coordinator/nAuth validation)
# AUTH_JWT_SECRET=
# AUTH_ISSUER=
# AUTH_AUDIENCE=
# AUTH_DISABLED=true
