# Course Builder Frontend — environment variables (Vite)

# Backend API base (with or without /api/v1 suffix)
VITE_API_URL=http://localhost:3000/api/v1

# Optional alias for API base URL
# VITE_API_BASE_URL=http://localhost:3000

# nAuth API (logout)
VITE_NAUTH_BASE_URL=http://localhost:4000

# nAuth / Directory login UI
VITE_NAUTH_FRONTEND_URL=http://localhost:5173

# Legacy dev-only service key (not used for user JWT auth)
# VITE_SERVICE_API_KEY=
